<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>disable</Nullable>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
    </PropertyGroup>

    <!-- NuGet package metadata -->
    <PropertyGroup>
        <PackageId>SimpleHMEngine</PackageId>
        <Version>0.3.0</Version>
        <Authors>Zakaria Djebbes</Authors>
        <Company>Zakaria Djebbes</Company>
        <Product>SimpleHMEngine</Product>
        <Title>SimpleHMEngine — a simple hand-made 2D game engine</Title>
        <Description>A small, hobby 2D game engine built on SFML.Net: game loop, scene/component tree, input binding, camera, simple collision, an immediate-mode drawing helper, and a lightweight UI toolkit. Great for prototypes, game jams and learning — not a production engine.</Description>
        <PackageTags>game;engine;2d;sfml;gamedev;game-engine;hobby</PackageTags>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageProjectUrl>https://github.com/ZakariaDjebbes/SimpleHMEngine</PackageProjectUrl>
        <RepositoryUrl>https://github.com/ZakariaDjebbes/SimpleHMEngine.git</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageReleaseNotes>0.3.0: Scene, persistence and input overhaul (contains breaking changes). Scene switching is now destructive and centralized in SceneManager.Load: the current scene is torn down and the next built fresh, removing the double/triple OnClose and the surprising side-effecting Scene.Current setter (Scene.Current is now a plain property). Added cross-scene persistence via the [Persistent] field attribute (one shared instance per component type, started once, spared from teardown, with field write-back), reachable through SceneManager.GetPersistentComponent&lt;T&gt;(). Added the [Detached] field attribute to opt a component field out of automatic discovery, and a cycle guard to the field scan. Input bindings are now two-tier: BindAction is scene-scoped and cleared on every switch, while the new BindGlobalAction overloads survive switches; InvokeActions iterates a snapshot so a binding that switches scenes can no longer corrupt the enumeration. BREAKING: removed the unused SceneManager scene registry APIs (RemoveScene, GetScene, GetRequiredScene, GetAllScenes). Also fixes Draw shared shapes inheriting rotation/outline/fill from a previous draw (options are now applied unconditionally with explicit fallbacks). Drawing ergonomics: added Draw.Clear(color) which clears the window Draw actually renders to (correct under SetDrawingWindow redirects), an implicit Color-to-DrawOptions/TextDrawOptions conversion so a color can be passed straight to a draw call, and a fluent DrawOptions builder (DrawOptions.Fill/Outline/Rotated plus WithFill/WithOutline/WithRotation/WithOpacity).</PackageReleaseNotes>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
      <DefineConstants>TRACE;DEBUG</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="SFML.Net" Version="2.6.0" />
    </ItemGroup>

    <!-- ZGeometry is published as its own package; depend on it normally.
         Publish ZGeometry to NuGet before (or alongside) this package. -->
    <ItemGroup>
      <ProjectReference Include="..\ZGeometry\ZGeometry.csproj" />
    </ItemGroup>

    <ItemGroup>
      <None Include="README.md" Pack="true" PackagePath="\" />
      <EmbeddedResource Include="Resources\DefaultResources\default.ttf">
        <LogicalName>Core.Resources.DefaultResources.default.ttf</LogicalName>
      </EmbeddedResource>
    </ItemGroup>

</Project>
