<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>disable</Nullable>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
    </PropertyGroup>

    <!-- NuGet package metadata -->
    <PropertyGroup>
        <PackageId>SimpleHMEngine</PackageId>
        <Version>0.3.1</Version>
        <Authors>Zakaria Djebbes</Authors>
        <Company>Zakaria Djebbes</Company>
        <Product>SimpleHMEngine</Product>
        <Title>SimpleHMEngine — a simple hand-made 2D game engine</Title>
        <Description>A small, hobby 2D game engine built on SFML.Net: game loop, scene/component tree, input binding, camera, simple collision, an immediate-mode drawing helper, and a lightweight UI toolkit. Great for prototypes, game jams and learning — not a production engine.</Description>
        <PackageTags>game;engine;2d;sfml;gamedev;game-engine;hobby</PackageTags>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageProjectUrl>https://github.com/ZakariaDjebbes/SimpleHMEngine</PackageProjectUrl>
        <RepositoryUrl>https://github.com/ZakariaDjebbes/SimpleHMEngine.git</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageReleaseNotes>0.3.1: Sprite drawing and a coordinate transform stack. Added Draw.Sprite, which draws a textured sprite immediately with no Scene or Component, configured through SpriteDrawOptions (an explicit texture or a texture path, an optional source rectangle, scale, origin and tint), with implicit conversions from Texture and string and a fluent builder; the engine now ships a small embedded default texture used by sprites with no texture set, and Sprite2D shares the cached texture instead of copying it per instance. Added a coordinate transform stack to Draw (Translate, Scale, Rotate, Push/Pop, and a disposable Draw.Pushed() scope with fluent calls) applied through RenderStates only, so it affects Draw's own output and never the window view, scenes or components, with a per-frame reset that bounds a forgotten Pop to a single frame. Added Draw.DrawMode(Anchor), which sets how the box primitives (Rectangle, Text, Sprite) anchor their position. Moved the drawing option types into the Core.Drawing.DrawOption namespace. Fixes: replaced the oversized 4096x4096 default texture with a 64x64 one and removed an unnecessary GCHandle pin on the default texture bytes. Added UiCanvas.Find&lt;T&gt;() to look up a root or nested UI element by type.</PackageReleaseNotes>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
      <DefineConstants>TRACE;DEBUG</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="SFML.Net" Version="2.6.0" />
    </ItemGroup>

    <!-- ZGeometry is published as its own package; depend on it normally.
         Publish ZGeometry to NuGet before (or alongside) this package. -->
    <ItemGroup>
      <ProjectReference Include="..\ZGeometry\ZGeometry.csproj" />
    </ItemGroup>

    <ItemGroup>
      <None Include="README.md" Pack="true" PackagePath="\" />
      <EmbeddedResource Include="Resources\DefaultResources\default.ttf">
        <LogicalName>Core.Resources.DefaultResources.default.ttf</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="Resources\DefaultResources\default.png">
        <LogicalName>Core.Resources.DefaultResources.default.png</LogicalName>
      </EmbeddedResource>
    </ItemGroup>

</Project>
