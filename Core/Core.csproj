<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>disable</Nullable>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
    </PropertyGroup>

    <!-- NuGet package metadata -->
    <PropertyGroup>
        <PackageId>SimpleHMEngine</PackageId>
        <Version>0.3.2</Version>
        <Authors>Zakaria Djebbes</Authors>
        <Company>Zakaria Djebbes</Company>
        <Product>SimpleHMEngine</Product>
        <Title>SimpleHMEngine — a simple hand-made 2D game engine</Title>
        <Description>A small, hobby 2D game engine built on SFML.Net: game loop, scene/component tree, input binding, camera, simple collision, an immediate-mode drawing helper, and a lightweight UI toolkit. Great for prototypes, game jams and learning — not a production engine.</Description>
        <PackageTags>game;engine;2d;sfml;gamedev;game-engine;hobby</PackageTags>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageProjectUrl>https://github.com/ZakariaDjebbes/SimpleHMEngine</PackageProjectUrl>
        <RepositoryUrl>https://github.com/ZakariaDjebbes/SimpleHMEngine.git</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageReleaseNotes>0.3.2: Extensible resource manager. What counts as a resource is now open: a loader registry (ResourceManager.RegisterLoader / RegisterStreamLoader / RegisterFallback) replaces the hardcoded type switch, so consumers can load their own types (JSON, config, custom formats) without modifying the engine. Built-in loaders now also cover raw text (string) and raw bytes (byte[]) alongside textures, fonts, sound buffers, sprites and colour palettes. Added non-file sources via streams: GetResource(key, stream) and GetEmbeddedResource(name); EmbeddedResources now routes through the manager. Robustness: GetResource returns a registered fallback on failure (textures and fonts fall back to the embedded defaults) or throws ResourceLoadException with context; added TryGetResource (no throw on a missing/invalid file); Clear and the new Unload(path) dispose native handles; cache keys are normalised to full paths; folder loads skip files that fail instead of aborting.</PackageReleaseNotes>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
      <DefineConstants>TRACE;DEBUG</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="SFML.Net" Version="2.6.0" />
    </ItemGroup>

    <!-- ZGeometry is published as its own package; depend on it normally.
         Publish ZGeometry to NuGet before (or alongside) this package. -->
    <ItemGroup>
      <ProjectReference Include="..\ZGeometry\ZGeometry.csproj" />
    </ItemGroup>

    <ItemGroup>
      <None Include="README.md" Pack="true" PackagePath="\" />
      <EmbeddedResource Include="Resources\DefaultResources\default.ttf">
        <LogicalName>Core.Resources.DefaultResources.default.ttf</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="Resources\DefaultResources\default.png">
        <LogicalName>Core.Resources.DefaultResources.default.png</LogicalName>
      </EmbeddedResource>
    </ItemGroup>

</Project>
