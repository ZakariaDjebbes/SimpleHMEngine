<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net8.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>disable</Nullable>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
    </PropertyGroup>

    <!-- NuGet package metadata -->
    <PropertyGroup>
        <PackageId>SimpleHMEngine</PackageId>
        <Version>0.4.0</Version>
        <Authors>Zakaria Djebbes</Authors>
        <Company>Zakaria Djebbes</Company>
        <Product>SimpleHMEngine</Product>
        <Title>SimpleHMEngine — a simple hand-made 2D game engine</Title>
        <Description>A small, hobby 2D game engine built on SFML.Net: game loop, scene/component tree, input binding, camera, simple collision, an immediate-mode drawing helper, and a lightweight UI toolkit. Great for prototypes, game jams and learning — not a production engine.</Description>
        <PackageTags>game;engine;2d;sfml;gamedev;game-engine;hobby</PackageTags>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageProjectUrl>https://github.com/ZakariaDjebbes/SimpleHMEngine</PackageProjectUrl>
        <RepositoryUrl>https://github.com/ZakariaDjebbes/SimpleHMEngine.git</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageReleaseNotes>0.4.0: TileMap rework (breaking). Tiles are now grouped by layer and each layer is drawn lowest-first, so Tile.Layer is finally honoured; layers can be shown/hidden individually with SetLayerVisible. Position and TileScale are applied through a render transform instead of being baked into the vertices, so moving or scaling a map is free and no longer needs a manual Rebuild. Tiles support per-tile tint, horizontal/vertical flip and per-tile scale. Geometry is emitted as triangles rather than the SFML-3-removed Quads primitive, and the map draws through the Draw facade (honouring SetDrawingWindow). The tile collection is now keyed by cell and layer with SetTile/AddTiles/RemoveTile/TryGetTile/ClearTiles and lazy, dirty-tracked rebuilds (no more manual Rebuild after every change); added a MapPixelSize bound and an embedded-default texture fallback. BREAKING: TileMap.Tiles is now a read-only enumeration — use AddTiles/SetTile to populate it; the texture argument defaults to the embedded texture instead of a hardcoded path. Added Draw.Vertices(VertexArray, RenderStates).  Fix default resources crashing on a null/empty resource path</PackageReleaseNotes>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    </PropertyGroup>

    <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
      <DefineConstants>TRACE;DEBUG</DefineConstants>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="SFML.Net" Version="2.6.0" />
    </ItemGroup>

    <!-- ZGeometry is published as its own package; depend on it normally.
         Publish ZGeometry to NuGet before (or alongside) this package. -->
    <ItemGroup>
      <ProjectReference Include="..\ZGeometry\ZGeometry.csproj" />
    </ItemGroup>

    <ItemGroup>
      <None Include="README.md" Pack="true" PackagePath="\" />
      <EmbeddedResource Include="Resources\DefaultResources\default.ttf">
        <LogicalName>Core.Resources.DefaultResources.default.ttf</LogicalName>
      </EmbeddedResource>
      <EmbeddedResource Include="Resources\DefaultResources\default.png">
        <LogicalName>Core.Resources.DefaultResources.default.png</LogicalName>
      </EmbeddedResource>
    </ItemGroup>

</Project>
